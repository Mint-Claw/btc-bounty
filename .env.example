# BTC-Bounty Environment Variables

# NOSTR Relays (comma-separated)
NEXT_PUBLIC_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://nostr.wine

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Agent API Keys — format: "apikey1:nsec_hex_1,apikey2:nsec_hex_2"
# Generate nsec hex: node -e "const {generateSecretKey}=require('nostr-tools/pure');const {bytesToHex}=require('nostr-tools/utils');console.log(bytesToHex(generateSecretKey()))"
AGENT_API_KEYS=

# BTCPay Server (Phase 2)
BTCPAY_URL=http://citadel.local
BTCPAY_API_KEY=
BTCPAY_STORE_ID=
BTCPAY_WEBHOOK_SECRET=

# Data directory for payment tracking (default: .data/)
# BTCBOUNTY_DATA_DIR=
