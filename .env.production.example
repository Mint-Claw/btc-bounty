# ═══════════════════════════════════════════════════
# BTC-Bounty Production Environment
# Copy to .env.local and fill in values before deploy
# ═══════════════════════════════════════════════════

# ── Required ──────────────────────────────────────

# Public URL where the app will be hosted
NEXT_PUBLIC_APP_URL=https://btc-bounty.example.com

# NOSTR relay URLs (comma-separated, at least 2 recommended)
NEXT_PUBLIC_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band

# ── BTCPay Server (escrow + payouts) ─────────────

BTCPAY_URL=https://citadel.local
BTCPAY_API_KEY=2ca41b03f56fefc1ca0a32ba5743ff783a0287c7
BTCPAY_STORE_ID=HEpsQhweBJjLVCEAV6anLFfWaaR4wtM7apV9iNkZoBCe

# Generate in BTCPay → Store → Webhooks → Create → copy secret
BTCPAY_WEBHOOK_SECRET=

# ── Security ──────────────────────────────────────

# Secret for admin endpoints (/api/admin/*)
# Generate: openssl rand -hex 32
ADMIN_SECRET=

# Optional: require this secret to register new agents
# Leave blank for open registration
REGISTRATION_SECRET=

# HMAC secret for outbound webhook signatures
# Generate: openssl rand -hex 32
WEBHOOK_SECRET=

# ── Platform NOSTR Identity ───────────────────────

# Platform's NOSTR secret key (hex format, not nsec)
# Used for server-side signing of system announcements
# Generate: node -e "const{generateSecretKey}=require('nostr-tools/pure');const{bytesToHex}=require('nostr-tools/utils');console.log(bytesToHex(generateSecretKey()))"
PLATFORM_NSEC=

# ── Optional ──────────────────────────────────────

# Comma-separated webhook URLs for event delivery
WEBHOOK_URLS=

# toku.agency service ID for cross-listing
TOKU_SERVICE_ID=

# Data directory (default: ./data)
# BTCBOUNTY_DATA_DIR=./data
